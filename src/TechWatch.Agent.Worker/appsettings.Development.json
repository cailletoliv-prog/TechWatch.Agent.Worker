{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "TechWatch": {
    "RunOnce": true,
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 120,
      "MaxItemsPerRun": 5
    },
    "Storage": {
      "ConnectionString": "Data Source=data/techwatch.db"
    },
    "Digest": {
      "OutputDirectory": "output/digests",
      "FileNameFormat": "yyyy-MM-dd"
    }
  }
}
