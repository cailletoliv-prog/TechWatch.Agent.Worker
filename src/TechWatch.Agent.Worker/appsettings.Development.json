{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "TechWatch": {
    "RunOnce": true,
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 120,
      "MaxItemsPerRun": 5
    },
    "Storage": {
      "ConnectionString": "Data Source=data/techwatch.db"
    },
    "Digest": {
      "OutputDirectory": "C:/Users/Olivier/Desktop/TechWatch/Digests",
      "FileNameFormat": "yyyy-MM-dd"
    },
    "Paths": {
      "BaseDirectory": ""
    }
  }
}
