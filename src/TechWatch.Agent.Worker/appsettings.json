{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "TechWatch": {
    "Sources": [
      {
        "Name": "Microsoft .NET Blog",
        "Type": "rss",
        "Url": "https://devblogs.microsoft.com/dotnet/feed/",
        "Enabled": true
      },
      {
        "Name": "ASP.NET Core Releases",
        "Type": "github-releases",
        "Url": "dotnet/aspnetcore",
        "Enabled": true
      }
    ],
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 120
    },
    "Filtering": {
      "PositiveKeywords": [
        ".NET",
        "C#",
        "ASP.NET Core",
        "EF Core",
        "Entity Framework",
        "Oracle",
        "Angular",
        "TypeScript",
        "LLM",
        "AI",
        "developer tooling"
      ],
      "NegativeKeywords": [
        "crypto",
        "blockchain",
        "web3",
        "sponsored",
        "marketing",
        "casino"
      ],
      "MinimumScore": 1
    },
    "Digest": {
      "OutputDirectory": "output/digests",
      "FileNameFormat": "yyyy-MM-dd"
    },
    "Storage": {
      "ConnectionString": "Data Source=data/techwatch.db"
    }
  }
}
