{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "TechWatch": {
    "RunOnce": true,
    "Sources": [
      {
        "Name": "Microsoft .NET Blog",
        "Type": "rss",
        "Url": "https://devblogs.microsoft.com/dotnet/feed/",
        "Enabled": true
      },
      {
        "Name": "EF Core Releases",
        "Type": "atom",
        "Url": "https://github.com/dotnet/efcore/releases.atom",
        "Enabled": true
      },
      {
        "Name": "ASP.NET Core Releases",
        "Type": "atom",
        "Url": "https://github.com/dotnet/aspnetcore/releases.atom",
        "Enabled": true
      }
    ],
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 120,
      "MaxItemsPerRun": 5
    },
    "Filtering": {
      "PositiveKeywords": [
        ".NET",
        "C#",
        "Entity Framework",
        "Oracle",
        "Angular",
        "TypeScript",
        "LLM",
        "AI",
        "developer tooling"
      ],
      "StrongPositiveKeywords": [
        "security",
        "breaking change",
        "EF Core",
        "ASP.NET Core",
        "AI agent",
        "MCP"
      ],
      "WeakPositiveKeywords": [
        "preview",
        "showcase",
        "demo",
        "tutorial"
      ],
      "NegativeKeywords": [
        "crypto",
        "blockchain",
        "web3",
        "sponsored",
        "marketing",
        "casino"
      ],
      "MinimumScore": 2,
      "PositiveKeywordWeight": 1,
      "StrongKeywordWeight": 3,
      "WeakKeywordWeight": 0,
      "WeakKeywordPenalty": 1
    },
    "Digest": {
      "OutputDirectory": "output/digests",
      "FileNameFormat": "yyyy-MM-dd"
    },
    "Storage": {
      "ConnectionString": "Data Source=data/techwatch.db"
    },
    "Paths": {
      "BaseDirectory": ""
    }
  }
}
